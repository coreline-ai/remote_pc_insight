# Public API endpoint for the deployed backend (Vercel API project)
NEXT_PUBLIC_API_BASE=https://<your-api-domain>

# Optional: Intro video URL shown on the landing page
# Example: /intro.mp4 (if file exists under web/public/intro.mp4)
NEXT_PUBLIC_INTRO_VIDEO_URL=

# AI Copilot UI flags (optional)
NEXT_PUBLIC_ENABLE_AI_COPILOT=false
NEXT_PUBLIC_AI_PROVIDER=glm45
